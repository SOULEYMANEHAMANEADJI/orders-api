# =============================================================================
# Environment variables for rest-api-orders
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit the actual .env file with secrets.

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=rest_api_orders_db
DB_USER=root
DB_PASSWORD=ReplaceWithStrongPassword

# --- Runtime ---
SPRING_PROFILES_ACTIVE=local
HIKARI_MAX_POOL_SIZE=10
HIKARI_MIN_IDLE=2

# --- Docker Compose overrides (optional) ---
# DB_PORT_EXTERNAL=3308
# APP_PORT=8633
